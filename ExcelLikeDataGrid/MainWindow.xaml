<Window x:Class="ExcelLikeDataGrid.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelLikeDataGrid"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Filterable DataGrid 1">
                <local:FilterableDataGrid ItemsSource="{Binding People}" Margin="10" AutoGenerateColumns="False">
                    <local:FilterableDataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="100"/>
                        <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="*"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                    </local:FilterableDataGrid.Columns>
                </local:FilterableDataGrid>
            </TabItem>
            <TabItem Header="Filterable DataGrid 2">
                <local:FilterableDataGrid ItemsSource="{Binding People2}" Margin="10" AutoGenerateColumns="False">
                    <local:FilterableDataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="100"/>
                        <DataGridTextColumn Header="Department" Binding="{Binding Department}" Width="*"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                    </local:FilterableDataGrid.Columns>
                </local:FilterableDataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
