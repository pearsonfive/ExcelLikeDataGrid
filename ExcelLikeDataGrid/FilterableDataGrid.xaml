<UserControl x:Class="ExcelLikeDataGrid.FilterableDataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ExcelLikeDataGrid"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Style for DataGrid Column Header featuring the Filter Button -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                            
                            <!-- The filter trigger button -->
                            <ToggleButton Grid.Column="1" x:Name="FilterButton" Width="20" Height="20" Margin="0,0,5,0"
                                          Click="FilterButton_Click" Tag="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Column}">
                                <Path Data="M 0 0 L 10 0 L 6 4 L 6 10 L 4 10 L 4 4 Z" Fill="DimGray" Stretch="Uniform" Margin="3"/>
                            </ToggleButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The DataGrid configured to use our header style, bound to mock data -->
        <DataGrid Grid.Row="0" x:Name="MainDataGrid" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" Margin="0"
                  GridLinesVisibility="All" AlternatingRowBackground="#FAFAFA" RowHeaderWidth="0">
        </DataGrid>

        <!-- Status Bar showing record counts -->
        <StatusBar Grid.Row="1" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <StatusBarItem HorizontalAlignment="Right" Margin="10,0">
                <TextBlock x:Name="RecordCountTextBlock" Foreground="#333333" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- The Shared Filter Popup that acts like Excel Filter Menu -->
        <Popup x:Name="FilterPopup" StaysOpen="False" Placement="Bottom">
            <Border Background="White" BorderBrush="Gray" BorderThickness="1" CornerRadius="2" MinWidth="180">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <CheckBox x:Name="SelectAllCheckBox" Content="(Select All)" IsChecked="True" Click="SelectAllCheckBox_Click" Margin="2,5" FontWeight="Bold"/>
                    <Separator Grid.Row="1" Margin="0,5"/>
                    
                    <ListBox Grid.Row="2" x:Name="FilterItemsListBox" MaxHeight="250" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Value}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="2" 
                                          Checked="FilterItem_CheckedChanged" Unchecked="FilterItem_CheckedChanged"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="OK" Width="70" Margin="0,0,5,0" Click="ApplyFilter_Click" Background="#0078D7" Foreground="White" BorderThickness="0" Padding="4"/>
                        <Button Content="Cancel" Width="70" Click="CancelFilter_Click" Background="#E1DFDD" BorderThickness="0" Padding="4"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
